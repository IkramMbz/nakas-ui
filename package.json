{
  "name": "nakas-ui",
  "version": "0.8.0",
  "type": "module",
  "description": "Reusable UI components and utilities to build consistent and beautiful interfaces",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/IkramMbz/nakas-ui"
  },
  "homepage": "https://ui.nakas.fr/",
  "bugs": {
    "url": "https://github.com/IkramMbz/nakas-ui/issues"
  },
  "keywords": [
    "accessibility",
    "components",
    "customization",
    "design-system",
    "frontend",
    "interface",
    "javascript",
    "reusable",
    "theme",
    "UI"
  ],
  "license": "MIT",
  "author": "Ikram Mbechezi",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "default": "./dist/components/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "scripts": {
    "build:css": "rimraf dist/styles && postcss src/assets/styles/index.css -o dist/styles/index.css --no-map",
    "build": "pnpm run clean && tsc && pnpm run build:css",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.2",
    "@storybook/addon-a11y": "^10.2.11",
    "@storybook/addon-docs": "^10.2.11",
    "@storybook/addon-vitest": "^10.2.11",
    "@storybook/html-vite": "^10.2.11",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@unocss/postcss": "^66.6.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "cssnano": "^7.1.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "playwright": "^1.58.2",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^5.0.10",
    "storybook": "^10.2.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "unocss": "^66.6.0",
    "vite": "^8.0.0-beta.13",
    "vitest": "^4.0.18"
  }
}